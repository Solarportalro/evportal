generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  COMPANY_USER
  COMPANY_ADMIN
  PLATFORM_ADMIN
  SUPPORT
}

enum CompanyType {
  STOCK_SELLER
  IMPORTER
  OFFICIAL_DEALER
  BROKER
  MIXED
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum VehicleFuelType {
  ELECTRIC
  PLUG_IN_HYBRID
  HYBRID
  GASOLINE
  DIESEL
}

enum VehicleRequestMode {
  EXACT_MODEL
  RECOMMENDATION
}

enum VehicleRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACTIVE
  OFFERS_RECEIVED
  CUSTOMER_DECIDING
  COMPANY_SELECTED
  CLOSED_SUCCESSFULLY
  CLOSED_WITHOUT_PURCHASE
  EXPIRED
  REJECTED
  CANCELLED
}

enum VehicleBodyType {
  SMALL_HATCHBACK
  SEDAN
  SUV_CROSSOVER
  VAN_BUSINESS
  OTHER
}

enum StockImportPreference {
  IN_STOCK_ONLY
  IMPORT_OK
  BOTH
  NOT_SURE
}

enum PurchaseTimeline {
  ASAP
  ONE_TO_THREE_MONTHS
  JUST_EXPLORING
}

enum HasSolar {
  YES
  NO
  PLANNING
  UNKNOWN
}

enum SolarChargingInterest {
  YES
  MAYBE_LATER
  NO
  NOT_ASKED
}

model GlobalCustomer {
  id              String   @id @default(cuid())
  normalizedPhone String?  @unique
  normalizedEmail String?  @unique
  fullName        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
}

model User {
  id                      String                   @id @default(cuid())
  globalCustomerId        String?
  globalCustomer          GlobalCustomer?          @relation(fields: [globalCustomerId], references: [id], onDelete: SetNull)
  email                   String?                  @unique
  phone                   String?                  @unique
  normalizedEmail         String?
  normalizedPhone         String?
  passwordHash            String?
  role                    UserRole
  preferredLanguage       String                   @default("hy")
  isEmailVerified         Boolean                  @default(false)
  isPhoneVerified         Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  companyMemberships      CompanyMember[]
  activityLogs            ActivityLog[]
  refreshTokens           RefreshToken[]
  setPasswordTokens       SetPasswordToken[]
  emailVerificationTokens EmailVerificationToken[]
  vehicleRequests         VehicleRequest[]

  @@index([normalizedEmail])
  @@index([normalizedPhone])
}

model Company {
  id         String          @id @default(cuid())
  publicName String
  legalName  String?
  type       CompanyType
  status     CompanyStatus   @default(PENDING)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  members    CompanyMember[]
}

model CompanyMember {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  role      UserRole @default(COMPANY_USER)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SetPasswordToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VehicleMake {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  models          VehicleModel[]
  vehicleRequests VehicleRequest[]

  @@index([isActive])
}

model VehicleModel {
  id              String           @id @default(cuid())
  makeId          String
  make            VehicleMake      @relation(fields: [makeId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  vehicleRequests VehicleRequest[]

  @@unique([makeId, name])
  @@unique([makeId, slug])
  @@index([makeId])
  @@index([isActive])
}

model VehicleRequest {
  id                    String                @id @default(cuid())
  customerId            String
  customer              User                  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  requestMode           VehicleRequestMode
  status                VehicleRequestStatus  @default(SUBMITTED)
  fuelType              VehicleFuelType
  makeId                String?
  make                  VehicleMake?          @relation(fields: [makeId], references: [id], onDelete: SetNull)
  modelId               String?
  model                 VehicleModel?         @relation(fields: [modelId], references: [id], onDelete: SetNull)
  manualMake            String?
  manualModel           String?
  preferredYearFrom     Int?
  preferredYearTo       Int?
  bodyType              VehicleBodyType?
  budgetMin             Int?
  budgetMax             Int?
  desiredRangeKm        Int?
  stockImportPreference StockImportPreference
  purchaseTimeline      PurchaseTimeline
  hasSolar              HasSolar
  solarChargingInterest SolarChargingInterest @default(NOT_ASKED)
  notes                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([fuelType])
  @@index([createdAt])
  @@index([makeId])
  @@index([modelId])
}
