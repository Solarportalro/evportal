# Runtime
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://evportal:evportal_dev_password@localhost:5432/evportal_dev?schema=public

# Auth secrets: use strong unique values in production
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SET_PASSWORD_TOKEN_EXPIRES_IN=1h

# Web/CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# One-time/idempotent first platform admin creation
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_PHONE=
ADMIN_FULL_NAME=
